# Backend Environment Variables (Spring Boot)
# For local development, these can be set in your IDE or a .env file if using a plugin.
# For production (Render/Railway), set these in the dashboard.

PORT=8085
DB_URL=jdbc:postgresql://<host>:<port>/<database>?sslmode=require
DB_USERNAME=neondb_owner
DB_PASSWORD=your-neon-password
JWT_SECRET=your-super-secret-key-at-least-256-bits-long-for-hs256-encryption
JWT_EXPIRATION=86400000
